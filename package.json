{
  "name": "collab-studio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "prisma generate && vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "prelint": "npm run prisma:generate",
    "lint": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:component",
    "test:unit": "node --test --import tsx src/**/*.test.ts",
    "test:component": "vitest run",
    "e2e": "playwright test",
    "e2e:production-smoke": "E2E_BASE_URL=https://collabstudio.run playwright test --config=playwright.production.config.ts",
    "prisma:generate": "prisma generate",
    "prisma:format": "prisma format",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx scripts/seed.ts",
    "create-admin": "tsx scripts/create-admin.ts",
    "smoke:stage3:production-safe": "tsx scripts/stage3_production_smoke.ts",
    "backfill:stage4b:lyrics": "tsx scripts/backfill-stage4b-lyrics.ts",
    "rehearsal:stage4b:lyrics": "tsx scripts/rehearse-stage4b-lyrics.ts",
    "audit-orphan-audio": "tsx scripts/audit-orphan-audio.ts",
    "backup": "bash scripts/backup.sh",
    "restore": "bash scripts/restore.sh"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@prisma/client": "^6.18.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "argon2": "^0.44.0",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.1.0",
    "express-session": "^1.18.2",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.1.0",
    "lucide-react": "^0.546.0",
    "morgan": "^1.10.1",
    "motion": "^12.23.24",
    "multer": "^2.0.2",
    "pg": "^8.16.3",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.18.1",
    "vite": "^6.2.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.15.5",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "jsdom": "^29.1.1",
    "prisma": "^6.18.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.9"
  }
}
