generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  user
}

enum ProjectRole {
  owner
  editor
  viewer
}

enum CapabilityPreset {
  legacy
  owner
  editor
  viewer
  custom
}

enum AccessScope {
  project
  track
}

enum InviteStatus {
  pending
  accepted
  revoked
  expired
}

enum BreakGlassStatus {
  active
  released
  expired
}

enum ProjectType {
  single
  album
}

enum TaskStatus {
  todo
  in_progress
  done
}

enum DiscussionTargetType {
  lyrics
}

enum ExternalProvider {
  google
  yandex
  telegram
  other
}

model User {
  id                String    @id @default(uuid()) @db.Uuid
  username          String    @unique
  email             String?   @unique
  displayName       String
  avatarUrl         String?
  passwordHash      String
  role              UserRole  @default(user)
  emailVerifiedAt   DateTime?
  ageAcknowledgedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  authAccounts                AuthAccount[]
  emailVerificationTokens     EmailVerificationToken[]
  passwordResetTokens         PasswordResetToken[]
  memberships                 ProjectMember[]
  trackAccessGrants           TrackAccessGrant[]
  lyricVersions               LyricVersion[]
  audioVersions               AudioVersion[]
  comments                    Comment[]                @relation("CommentAuthor")
  resolvedComments            Comment[]                @relation("CommentResolver")
  chatMessages                ChatMessage[]
  createdTasks                Task[]                   @relation("TaskCreator")
  assignedTasks               Task[]                   @relation("TaskAssignee")
  annotations                 Annotation[]
  notifications               Notification[]           @relation("NotificationRecipient")
  actedNotifications          Notification[]           @relation("NotificationActor")
  createdInvites              ProjectInvite[]          @relation("InviteCreator")
  acceptedInvites             ProjectInvite[]          @relation("InviteAcceptor")
  assignedInvites             ProjectInvite[]          @relation("InviteTargetUser")
  initiatedOwnershipTransfers OwnershipTransferAudit[] @relation("OwnershipTransferFrom")
  receivedOwnershipTransfers  OwnershipTransferAudit[] @relation("OwnershipTransferTo")
  breakGlassInitiated         BreakGlassAccessAudit[]  @relation("BreakGlassInitiator")
  activityEvents              ActivityEvent[]
  lyricsEditLeases            LyricsEditLease[]
  discussionThreads           DiscussionThread[]        @relation("DiscussionThreadCreator")
  resolvedDiscussionThreads   DiscussionThread[]        @relation("DiscussionThreadResolver")
  discussionMessages          DiscussionMessage[]

  @@index([role])
  @@index([createdAt])
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuthAccount {
  id                String           @id @default(uuid()) @db.Uuid
  userId            String           @db.Uuid
  provider          ExternalProvider
  providerAccountId String
  createdAt         DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@unique([userId, provider])
  @@index([userId])
  @@index([provider])
}

model Session {
  sid    String   @id
  sess   Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "IDX_session_expire")
  @@map("session")
}

model Project {
  id           String      @id @default(uuid()) @db.Uuid
  title        String
  type         ProjectType
  coverUrl     String?
  tags         String[]    @default([])
  quotaTier    String      @default("free")
  entitlements Json        @default("{}")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  members            ProjectMember[]
  invites            ProjectInvite[]
  trackAccessGrants  TrackAccessGrant[]
  guestLinks         GuestLink[]
  ownershipTransfers OwnershipTransferAudit[]
  breakGlassAudits   BreakGlassAccessAudit[]
  activityEvents     ActivityEvent[]
  tracks             Track[]
  notifications      Notification[]
  discussionThreads  DiscussionThread[]

  @@index([updatedAt])
  @@index([createdAt])
}

model ProjectMember {
  id                 String           @id @default(uuid()) @db.Uuid
  projectId          String           @db.Uuid
  userId             String           @db.Uuid
  role               ProjectRole
  capabilityPreset   CapabilityPreset @default(legacy)
  customCapabilities Json             @default("{}")
  createdAt          DateTime         @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@index([userId, role])
}

model ProjectInvite {
  id                 String       @id @default(uuid()) @db.Uuid
  projectId          String       @db.Uuid
  createdById        String       @db.Uuid
  invitedUserId      String?      @db.Uuid
  invitedEmail       String?
  role               ProjectRole
  scope              AccessScope  @default(project)
  trackId            String?      @db.Uuid
  tokenHash          String       @unique
  status             InviteStatus @default(pending)
  customCapabilities Json         @default("{}")
  expiresAt          DateTime
  revokedAt          DateTime?
  acceptedAt         DateTime?
  acceptedById       String?      @db.Uuid
  createdAt          DateTime     @default(now())

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  track       Track?  @relation(fields: [trackId], references: [id], onDelete: SetNull)
  createdBy   User    @relation("InviteCreator", fields: [createdById], references: [id], onDelete: Restrict)
  acceptedBy  User?   @relation("InviteAcceptor", fields: [acceptedById], references: [id], onDelete: SetNull)
  invitedUser User?   @relation("InviteTargetUser", fields: [invitedUserId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([trackId])
  @@index([invitedEmail])
  @@index([status])
  @@index([expiresAt])
}

model TrackAccessGrant {
  id                 String      @id @default(uuid()) @db.Uuid
  projectId          String      @db.Uuid
  trackId            String      @db.Uuid
  userId             String      @db.Uuid
  role               ProjectRole @default(viewer)
  canDownload        Boolean     @default(false)
  customCapabilities Json        @default("{}")
  expiresAt          DateTime?
  revokedAt          DateTime?
  createdAt          DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  track   Track   @relation(fields: [trackId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([trackId, userId])
  @@index([projectId])
  @@index([trackId])
  @@index([userId])
  @@index([expiresAt])
}

model GuestLink {
  id          String    @id @default(uuid()) @db.Uuid
  projectId   String    @db.Uuid
  trackId     String?   @db.Uuid
  tokenHash   String    @unique
  canListen   Boolean   @default(true)
  canDownload Boolean   @default(false)
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  track   Track?  @relation(fields: [trackId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([trackId])
  @@index([expiresAt])
}

model OwnershipTransferAudit {
  id         String   @id @default(uuid()) @db.Uuid
  projectId  String   @db.Uuid
  fromUserId String   @db.Uuid
  toUserId   String   @db.Uuid
  reason     String
  createdAt  DateTime @default(now())

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromUser User    @relation("OwnershipTransferFrom", fields: [fromUserId], references: [id], onDelete: Restrict)
  toUser   User    @relation("OwnershipTransferTo", fields: [toUserId], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([fromUserId])
  @@index([toUserId])
}

model BreakGlassAccessAudit {
  id          String           @id @default(uuid()) @db.Uuid
  projectId   String           @db.Uuid
  adminUserId String           @db.Uuid
  reason      String
  status      BreakGlassStatus @default(active)
  expiresAt   DateTime
  releasedAt  DateTime?
  createdAt   DateTime         @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  adminUser User    @relation("BreakGlassInitiator", fields: [adminUserId], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([adminUserId])
  @@index([status])
  @@index([expiresAt])
}

model ActivityEvent {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @db.Uuid
  actorId   String?  @db.Uuid
  type      String
  payload   Json     @default("{}")
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([actorId])
  @@index([type])
  @@index([createdAt])
}

model Track {
  id              String   @id @default(uuid()) @db.Uuid
  projectId       String   @db.Uuid
  title           String
  lyrics          String   @default("")
  lyricsDocument  Json?
  lyricsPlainText String?
  lyricsRevision  Int      @default(0)
  tags            String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project         Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lyricVersions   LyricVersion[]
  audioVersions   AudioVersion[]
  comments        Comment[]
  chatMessages    ChatMessage[]
  tasks           Task[]
  annotations     Annotation[]
  notifications   Notification[]
  invites         ProjectInvite[]
  accessGrants    TrackAccessGrant[]
  guestLinks        GuestLink[]
  lyricsEditLease   LyricsEditLease?
  discussionThreads DiscussionThread[]

  @@index([projectId])
  @@index([projectId, updatedAt])
}

model LyricsEditLease {
  id          String   @id @default(uuid()) @db.Uuid
  trackId     String   @unique @db.Uuid
  userId      String   @db.Uuid
  tokenHash   String   @unique
  acquiredAt  DateTime @default(now())
  heartbeatAt DateTime @default(now())
  expiresAt   DateTime

  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model LyricVersion {
  id            String   @id @default(uuid()) @db.Uuid
  trackId       String   @db.Uuid
  authorId      String?  @db.Uuid
  lyrics        String
  document      Json?
  plainText     String?
  schemaVersion Int?
  label         String
  isOriginal    Boolean  @default(false)
  createdAt     DateTime @default(now())

  track              Track               @relation(fields: [trackId], references: [id], onDelete: Cascade)
  author             User?               @relation(fields: [authorId], references: [id], onDelete: SetNull)
  sourceDiscussionThreads DiscussionThread[]

  @@index([trackId])
  @@index([authorId])
  @@index([trackId, createdAt])
  @@index([trackId, isOriginal])
}

model AudioVersion {
  id               String  @id @default(uuid()) @db.Uuid
  trackId          String  @db.Uuid
  uploadedById     String? @db.Uuid
  originalFilename String
  storedFilename   String?
  storageKey       String?
  mimeType         String?
  sizeBytes        Int?
  durationSeconds  Float?

  externalUrl      String?
  isExternal       Boolean           @default(false)
  externalProvider ExternalProvider?
  versionNumber    Int
  createdAt        DateTime          @default(now())

  track      Track @relation(fields: [trackId], references: [id], onDelete: Cascade)
  uploadedBy User? @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@unique([trackId, versionNumber])
  @@index([trackId])
  @@index([uploadedById])
  @@index([trackId, createdAt])
}

model Comment {
  id           String    @id @default(uuid()) @db.Uuid
  trackId      String    @db.Uuid
  authorId     String?   @db.Uuid
  resolvedById String?   @db.Uuid
  lineIndex    Int?
  text         String
  resolved     Boolean   @default(false)
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  track      Track @relation(fields: [trackId], references: [id], onDelete: Cascade)
  author     User? @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  resolvedBy User? @relation("CommentResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([trackId])
  @@index([authorId])
  @@index([resolvedById])
  @@index([trackId, resolved])
  @@index([trackId, createdAt])
}


model DiscussionThread {
  id                   String               @id @default(uuid()) @db.Uuid
  projectId            String               @db.Uuid
  trackId              String               @db.Uuid
  targetType           DiscussionTargetType @default(lyrics)
  createdById          String?              @db.Uuid
  resolvedById         String?              @db.Uuid
  sourceLyricVersionId String?              @db.Uuid
  sourceLyricsRevision Int?
  anchorBlockId        String?
  anchorStartOffsetHint Int?
  anchorEndOffsetHint  Int?
  anchorQuote          String?
  anchorPrefix         String?
  anchorSuffix         String?
  resolvedAt           DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  project            Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  track              Track               @relation(fields: [trackId], references: [id], onDelete: Cascade)
  createdBy          User?               @relation("DiscussionThreadCreator", fields: [createdById], references: [id], onDelete: SetNull)
  resolvedBy         User?               @relation("DiscussionThreadResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  sourceLyricVersion LyricVersion?       @relation(fields: [sourceLyricVersionId], references: [id], onDelete: SetNull)
  messages           DiscussionMessage[]

  @@index([projectId])
  @@index([trackId])
  @@index([createdById])
  @@index([resolvedById])
  @@index([trackId, resolvedAt])
  @@index([trackId, createdAt])
  @@index([trackId, anchorBlockId])
}

model DiscussionMessage {
  id        String   @id @default(uuid()) @db.Uuid
  threadId   String   @db.Uuid
  authorId   String?  @db.Uuid
  body       String
  editedAt   DateTime?
  deletedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  thread DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User?            @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([threadId])
  @@index([authorId])
  @@index([threadId, createdAt])
}

model ChatMessage {
  id        String   @id @default(uuid()) @db.Uuid
  trackId   String   @db.Uuid
  authorId  String?  @db.Uuid
  text      String
  createdAt DateTime @default(now())

  track  Track @relation(fields: [trackId], references: [id], onDelete: Cascade)
  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([trackId])
  @@index([authorId])
  @@index([trackId, createdAt])
}

model Task {
  id           String     @id @default(uuid()) @db.Uuid
  trackId      String     @db.Uuid
  createdById  String?    @db.Uuid
  assignedToId String?    @db.Uuid
  title        String
  status       TaskStatus @default(todo)
  description  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  track      Track @relation(fields: [trackId], references: [id], onDelete: Cascade)
  createdBy  User? @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  assignedTo User? @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([trackId])
  @@index([createdById])
  @@index([assignedToId])
  @@index([trackId, status])
  @@index([assignedToId, status])
}

model Annotation {
  id               String   @id @default(uuid()) @db.Uuid
  trackId          String   @db.Uuid
  authorId         String?  @db.Uuid
  timestampSeconds Int
  text             String
  createdAt        DateTime @default(now())

  track  Track @relation(fields: [trackId], references: [id], onDelete: Cascade)
  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([trackId])
  @@index([authorId])
  @@index([trackId, timestampSeconds])
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  actorId   String?  @db.Uuid
  projectId String   @db.Uuid
  trackId   String?  @db.Uuid
  message   String
  type      String
  read      Boolean  @default(false)
  actorName String?
  createdAt DateTime @default(now())

  user    User    @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor   User?   @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  track   Track?  @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([actorId])
  @@index([projectId])
  @@index([trackId])
  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([projectId, createdAt])
}
